{
  "name": "agent-tool-observability-demo",
  "version": "1.0.0",
  "description": "A small TypeScript CLI that simulates agent tool calls and prints structured observability traces.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
